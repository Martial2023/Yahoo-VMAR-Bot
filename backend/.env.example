# --- Database (Postgres, géré par Prisma côté frontend) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/botvmar

# --- API control (token partagé avec le frontend Vercel) ---
API_HOST=0.0.0.0
API_PORT=8000
API_TOKEN=change-me-to-a-long-random-string

# --- OpenRouter ---
OPENROUTER_KEY=

# --- Yahoo account (login interactif via scripts/login.py) ---
YAHOO_EMAIL=
YAHOO_PASSWORD=

# --- Reddit (script-type app — https://www.reddit.com/prefs/apps) ---
# Format requis pour le user agent : "<platform>:<app-id>:<version> (by /u/<your-username>)"
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=BotVMAR/0.1 (by /u/your_username)

# --- Proxy (optionnel) ---
PROXY_URL=

# --- SMTP (alertes email) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- Telegram (alertes optionnelles) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Logging ---
LOG_LEVEL=INFO

# --- Worker behaviour ---
# Run a full cycle for all enabled platforms immediately on startup (true/false)
RUN_ON_STARTUP=true

# --- Session file (relatif au dossier backend/) ---
SESSION_FILE=sessions/yahoo_session.json
